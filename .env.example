# arkiv — Environment Variables
# Copy to .env and customize as needed.

# ── Paths ──────────────────────────────────────────────────
# ARKIV_DB_PATH=./media.db              # SQLite database path
# ARKIV_CHROMA_PATH=./chroma_db         # ChromaDB vector store directory
# ARKIV_THUMBNAILS_DIR=./thumbnails     # Thumbnail output directory

# ── Ollama ─────────────────────────────────────────────────
# ARKIV_OLLAMA_URL=http://localhost:11434   # Ollama API endpoint
# ARKIV_EMBED_MODEL=nomic-embed-text       # Embedding model name
# ARKIV_VISION_MODEL=llava:7b              # Vision model for frame analysis

# ── Whisper ────────────────────────────────────────────────
# macOS Apple Silicon default: mlx-community/whisper-large-v3-mlx
# Docker / NVIDIA / CPU: large-v3-turbo (faster-whisper format)
# ARKIV_WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# ── Server ─────────────────────────────────────────────────
# ARKIV_HOST=0.0.0.0                    # Server bind address
# ARKIV_PORT=8501                       # Server port
