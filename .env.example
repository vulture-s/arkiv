# arkiv — Environment Variables
# Copy to .env and customize

# Database paths (default: relative to project root)
# ARKIV_DB_PATH=./media.db
# ARKIV_CHROMA_PATH=./chroma_db
# ARKIV_THUMBNAILS_DIR=./thumbnails

# Ollama server (default: localhost)
# ARKIV_OLLAMA_URL=http://localhost:11434
# ARKIV_EMBED_MODEL=nomic-embed-text
# ARKIV_VISION_MODEL=llava:7b

# Whisper model
# macOS: mlx-community/whisper-large-v3-mlx
# CUDA:  large-v3 (via faster-whisper)
# ARKIV_WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# Server
# ARKIV_HOST=0.0.0.0
# ARKIV_PORT=8501
